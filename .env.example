SECRET_KEY=replace-with-a-long-random-secret
FLASK_DEBUG=0
PORT=5000

# Initial management accounts (used only when running: flask --app app init-db)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-strong-password
MANAGER_NAME=Academy Manager
MANAGER_EMAIL=manager@example.com
MANAGER_PASSWORD=change-this-strong-password
ACCOUNTANT_NAME=Accounting Manager
ACCOUNTANT_EMAIL=accounts@example.com
ACCOUNTANT_PASSWORD=change-this-strong-password

# Gmail SMTP (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=1
